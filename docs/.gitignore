
---

## `.gitignore`

```gitignore
# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

# Distribución / empaquetado
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# =========================
# Entornos virtuales
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Django
# =========================
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/

# Archivos estáticos recolectados
staticfiles/

# =========================
# Variables de entorno
# =========================
.env
.env.*
!.env.example

# =========================
# Pytest / cobertura / cachés
# =========================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache/

# =========================
# Linters / type checkers
# =========================
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# VS Code / JetBrains / editores
# =========================
.vscode/
.idea/
*.iml

# =========================
# SO
# =========================
.DS_Store
Thumbs.db

# =========================
# Docker
# =========================
*.pid
docker-compose.override.yml

# =========================
# Node / frontend auxiliar
# =========================
node_modules/

# =========================
# Archivos temporales
# =========================
*.tmp
*.swp
*.swo
*~